NODE_ENV=DEVELOPMENT

# MongoDB - IMPORTANT: See SETUP.md for IP whitelist instructions
# Use this MongoDB URI (ask project lead for credentials)
MONGO_URI=mongodb+srv://[username]:[password]@cluster0.evoccgn.mongodb.net/SignCast?appName=Cluster0

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Legacy JWT (no longer used for auth, kept for compatibility if needed)
JWT_SECRET=
JWT_EXPIRES_TIME=70d
COOKIE_EXPIRES_TIME=7

# SMTP / Mailtrap
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_EMAIL=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=
